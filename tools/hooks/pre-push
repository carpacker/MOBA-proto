#!/bin/sh
# pre-push gate (M1.4): /WX build + ctest. Blocks the push if anything fails.
#
# Git on Windows runs hooks through sh, which has NO Visual Studio environment, so
# this is a thin shim that hands off to ctest-gate.bat (it sources vcvars, builds the
# ci/ /WX preset, and runs ctest). Activate the hook once with:
#
#     git config core.hooksPath tools/hooks
#
# Bypass deliberately (e.g. a docs-only push) with:  git push --no-verify
root="$(git rev-parse --show-toplevel)" || exit 1
gate="$root/tools/hooks/ctest-gate.bat"

echo "[pre-push] /WX build + ctest gate…"
if command -v cygpath >/dev/null 2>&1; then
    cmd.exe //c "$(cygpath -w "$gate")"
else
    cmd.exe //c "$gate"
fi
status=$?

if [ "$status" -ne 0 ]; then
    echo "[pre-push] BLOCKED (exit $status): build or tests failed."
    echo "[pre-push] Fix them, or override deliberately with: git push --no-verify"
fi
exit $status
